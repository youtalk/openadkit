# syntax=docker/dockerfile:1
# check=skip=InvalidDefaultArgInFrom,UndefinedVar
ARG UNIVERSE_COMMON_DEVEL_IMAGE
ARG UNIVERSE_COMMON_IMAGE

# =============================================================================
# Build stage: localization-mapping-devel
# =============================================================================
FROM ${UNIVERSE_COMMON_DEVEL_IMAGE} AS localization-mapping-devel
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ARG ROS_DISTRO

# autoware_pcl_extensions / autoware_pointcloud_preprocessor / autoware_automatic_pose_initializer
# are pulled in until https://github.com/autowarefoundation/autoware_universe/issues/10282 is resolved.
COPY --parents --chown=${USERNAME}:${USERNAME} \
    autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_localization_launch/**/package.xml \
    autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_map_launch/**/package.xml \
    autoware/src/universe/autoware_universe/localization/**/package.xml \
    autoware/src/universe/autoware_universe/map/**/package.xml \
    autoware/src/universe/autoware_universe/sensing/autoware_pcl_extensions/**/package.xml \
    autoware/src/universe/autoware_universe/sensing/autoware_pointcloud_preprocessor/**/package.xml \
    autoware/src/universe/autoware_universe/system/autoware_default_adapi_helpers/autoware_automatic_pose_initializer/**/package.xml \
    /tmp/

RUN --mount=type=cache,id=apt-cache-${ROS_DISTRO},target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=apt-lists-${ROS_DISTRO},target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    . "/opt/ros/${ROS_DISTRO}/setup.sh" && \
    . /opt/autoware/setup.sh && \
    rosdep install -y --from-paths /tmp/autoware/src /opt/autoware/share \
      --ignore-src --rosdistro "${ROS_DISTRO}" \
      --dependency-types=build --dependency-types=build_export \
      --dependency-types=buildtool --dependency-types=buildtool_export \
      --dependency-types=test

RUN --mount=type=bind,source=autoware/src,target=/tmp/autoware/src \
    --mount=type=cache,id=ccache-${ROS_DISTRO},target=/home/aw/.ccache,uid=1000,gid=1000 \
    . "/opt/ros/${ROS_DISTRO}/setup.sh" && \
    . /opt/autoware/setup.sh && \
    colcon build \
      --base-paths \
        /tmp/autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_localization_launch \
        /tmp/autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_map_launch \
        /tmp/autoware/src/universe/autoware_universe/localization \
        /tmp/autoware/src/universe/autoware_universe/map \
        /tmp/autoware/src/universe/autoware_universe/sensing/autoware_pcl_extensions \
        /tmp/autoware/src/universe/autoware_universe/sensing/autoware_pointcloud_preprocessor \
        /tmp/autoware/src/universe/autoware_universe/system/autoware_default_adapi_helpers/autoware_automatic_pose_initializer \
      --install-base /opt/autoware \
      --cmake-args -DCMAKE_BUILD_TYPE=Release && \
    rm -rf build log

RUN --mount=type=cache,id=apt-cache-${ROS_DISTRO},target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=apt-lists-${ROS_DISTRO},target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    . "/opt/ros/${ROS_DISTRO}/setup.sh" && \
    rosdep install -y --from-paths /tmp/autoware/src /opt/autoware/share \
      --ignore-src --rosdistro "${ROS_DISTRO}" \
      --dependency-types=exec && \
    rm -rf /tmp/autoware

# =============================================================================
# Runtime stage: localization-mapping
# =============================================================================
FROM ${UNIVERSE_COMMON_IMAGE} AS localization-mapping
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ARG ROS_DISTRO

USER root
COPY --from=localization-mapping-devel /opt/autoware /opt/autoware
RUN find /opt/autoware -name '*.so' -exec strip --strip-unneeded {} +

COPY --parents --chown=${USERNAME}:${USERNAME} \
    autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_localization_launch/**/package.xml \
    autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_map_launch/**/package.xml \
    autoware/src/universe/autoware_universe/localization/**/package.xml \
    autoware/src/universe/autoware_universe/map/**/package.xml \
    autoware/src/universe/autoware_universe/sensing/autoware_pcl_extensions/**/package.xml \
    autoware/src/universe/autoware_universe/sensing/autoware_pointcloud_preprocessor/**/package.xml \
    autoware/src/universe/autoware_universe/system/autoware_default_adapi_helpers/autoware_automatic_pose_initializer/**/package.xml \
    /tmp/

RUN --mount=type=cache,id=apt-cache-${ROS_DISTRO},target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=apt-lists-${ROS_DISTRO},target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    . "/opt/ros/${ROS_DISTRO}/setup.sh" && \
    rosdep install -y --from-paths /tmp /opt/autoware/share \
      --dependency-types=exec --ignore-src --rosdistro "${ROS_DISTRO}" && \
    rm -rf /tmp/*
