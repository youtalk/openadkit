# syntax=docker/dockerfile:1
# check=skip=InvalidDefaultArgInFrom,UndefinedVar
ARG UNIVERSE_COMMON_DEVEL_IMAGE
ARG UNIVERSE_COMMON_IMAGE

# =============================================================================
# Build stage: vehicle-system-devel
# =============================================================================
FROM ${UNIVERSE_COMMON_DEVEL_IMAGE} AS vehicle-system-devel
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ARG ROS_DISTRO

COPY --parents --chown=${USERNAME}:${USERNAME} \
    autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_vehicle_launch/**/package.xml \
    autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_system_launch/**/package.xml \
    autoware/src/universe/autoware_universe/vehicle/**/package.xml \
    autoware/src/universe/autoware_universe/system/**/package.xml \
    autoware/src/universe/autoware_universe/localization/autoware_pose2twist/**/package.xml \
    autoware/src/universe/autoware_universe/planning/planning_validator/**/package.xml \
    autoware/src/sensor_component/external/sensor_component_description/**/package.xml \
    /tmp/

RUN --mount=type=cache,id=apt-cache-${ROS_DISTRO},target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=apt-lists-${ROS_DISTRO},target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    . "/opt/ros/${ROS_DISTRO}/setup.sh" && \
    . /opt/autoware/setup.sh && \
    rosdep install -y --from-paths /tmp/autoware/src \
      --ignore-src --rosdistro "${ROS_DISTRO}" \
      --dependency-types=build --dependency-types=build_export \
      --dependency-types=buildtool --dependency-types=buildtool_export \
      --dependency-types=test

RUN --mount=type=bind,source=autoware/src,target=/tmp/autoware/src \
    --mount=type=cache,id=ccache-${ROS_DISTRO},target=/home/aw/.ccache,uid=1000,gid=1000 \
    . "/opt/ros/${ROS_DISTRO}/setup.sh" && \
    . /opt/autoware/setup.sh && \
    colcon build \
      --base-paths \
        /tmp/autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_vehicle_launch \
        /tmp/autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_system_launch \
        /tmp/autoware/src/universe/autoware_universe/vehicle \
        /tmp/autoware/src/universe/autoware_universe/system \
        /tmp/autoware/src/universe/autoware_universe/localization/autoware_pose2twist \
        /tmp/autoware/src/universe/autoware_universe/planning/planning_validator \
        /tmp/autoware/src/sensor_component/external/sensor_component_description \
      --install-base /opt/autoware \
      --cmake-args -DCMAKE_BUILD_TYPE=Release && \
    rm -rf build log

RUN --mount=type=cache,id=apt-cache-${ROS_DISTRO},target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=apt-lists-${ROS_DISTRO},target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    . "/opt/ros/${ROS_DISTRO}/setup.sh" && \
    rosdep install -y --from-paths /tmp/autoware/src \
      --ignore-src --rosdistro "${ROS_DISTRO}" \
      --dependency-types=exec && \
    rm -rf /tmp/autoware

# =============================================================================
# Runtime stage: vehicle-system
# =============================================================================
FROM ${UNIVERSE_COMMON_IMAGE} AS vehicle-system
SHELL ["/bin/bash", "-o", "pipefail", "-c"]
ARG ROS_DISTRO

USER root
COPY --from=vehicle-system-devel /opt/autoware /opt/autoware
RUN find /opt/autoware -name '*.so' -exec strip --strip-unneeded {} +

COPY --parents --chown=${USERNAME}:${USERNAME} \
    autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_vehicle_launch/**/package.xml \
    autoware/src/launcher/autoware_launch/tier4_universe_launch/tier4_system_launch/**/package.xml \
    autoware/src/universe/autoware_universe/vehicle/**/package.xml \
    autoware/src/universe/autoware_universe/system/**/package.xml \
    autoware/src/universe/autoware_universe/localization/autoware_pose2twist/**/package.xml \
    autoware/src/universe/autoware_universe/planning/planning_validator/**/package.xml \
    autoware/src/sensor_component/external/sensor_component_description/**/package.xml \
    /tmp/

RUN --mount=type=cache,id=apt-cache-${ROS_DISTRO},target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=apt-lists-${ROS_DISTRO},target=/var/lib/apt/lists,sharing=locked \
    apt-get update && \
    . "/opt/ros/${ROS_DISTRO}/setup.sh" && \
    rosdep install -y --from-paths /tmp \
      --dependency-types=exec --ignore-src --rosdistro "${ROS_DISTRO}" && \
    rm -rf /tmp/*
